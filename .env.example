# ─── Hospital Kiosk — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# The server reads these on startup.

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Get a free Groq API key at: https://console.groq.com
# Used for BOTH transcription (Groq Whisper) AND chat (Groq LLM)
GROQ_API_KEY=your_groq_api_key_here

# ── OPTIONAL: Groq model overrides ────────────────────────────────────────────
# LLM model (chat / triage / registration)
# Options: llama-3.1-8b-instant (fast), llama-3.3-70b-versatile (smarter)
GROQ_MODEL=llama-3.1-8b-instant

# Whisper model (transcription)
# Options: whisper-large-v3-turbo (fast), whisper-large-v3 (most accurate)
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Timeouts (seconds)
GROQ_TIMEOUT=30
GROQ_WHISPER_TIMEOUT=30

# ── OPTIONAL: Face recognition ────────────────────────────────────────────────
# Cosine distance threshold for face match (lower = stricter)
FACE_MATCH_THRESHOLD=0.40

# ── OPTIONAL: Security ────────────────────────────────────────────────────────
# API key required for /register and /patients delete endpoints
# KIOSK_API_KEY=change-me-in-production

# CORS origins (comma-separated, * = allow all)
# KIOSK_CORS_ORIGINS=http://localhost:5173,http://localhost:8000
